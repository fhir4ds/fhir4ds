# ----- Quantity Operations Extended -----

# quantityValue: extract value
query R
SELECT quantityValue('{"value":140,"code":"mm[Hg]","system":"http://unitsofmeasure.org"}');
----
140.0

# quantityUnit: extract unit
query I
SELECT quantityUnit('{"value":140,"code":"mm[Hg]","system":"http://unitsofmeasure.org"}');
----
mm[Hg]

# quantityValue: NULL → NULL
query I
SELECT quantityValue(NULL);
----
NULL

# quantityUnit: NULL → NULL
query I
SELECT quantityUnit(NULL);
----
NULL

# quantityAdd: same units
query I
SELECT quantityAdd('{"value":10,"code":"mg","system":"http://unitsofmeasure.org"}', '{"value":5,"code":"mg","system":"http://unitsofmeasure.org"}');
----
{"value":15.0,"unit":"mg","code":"mg","system":"http://unitsofmeasure.org"}

# quantitySubtract: same units
query I
SELECT quantitySubtract('{"value":10,"code":"mg","system":"http://unitsofmeasure.org"}', '{"value":3,"code":"mg","system":"http://unitsofmeasure.org"}');
----
{"value":7.0,"unit":"mg","code":"mg","system":"http://unitsofmeasure.org"}

# quantityCompare: equal
query I
SELECT quantityCompare('{"value":10,"code":"mg","system":"http://unitsofmeasure.org"}', '{"value":10,"code":"mg","system":"http://unitsofmeasure.org"}', '==');
----
true

# quantityCompare: less than
query I
SELECT quantityCompare('{"value":5,"code":"mg","system":"http://unitsofmeasure.org"}', '{"value":10,"code":"mg","system":"http://unitsofmeasure.org"}', '<');
----
true

# quantityCompare: greater than
query I
SELECT quantityCompare('{"value":10,"code":"mg","system":"http://unitsofmeasure.org"}', '{"value":5,"code":"mg","system":"http://unitsofmeasure.org"}', '>');
----
true

# quantityAdd: NULL → NULL
query I
SELECT quantityAdd(NULL, '{"value":5,"code":"mg","system":"http://unitsofmeasure.org"}');
----
NULL

# quantitySubtract: NULL → NULL
query I
SELECT quantitySubtract(NULL, '{"value":5,"code":"mg","system":"http://unitsofmeasure.org"}');
----
NULL

# quantityCompare: NULL → NULL
query I
SELECT quantityCompare(NULL, '{"value":5,"code":"mg","system":"http://unitsofmeasure.org"}', '=');
----
NULL

