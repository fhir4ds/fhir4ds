query I
SELECT mathAbs('-999999');
----
999999

# mathCeiling: already integer decimal
query I
SELECT mathCeiling('5.0');
----
5

# mathFloor: already integer decimal
query I
SELECT mathFloor('5.0');
----
5

# mathRound: zero
query I
SELECT mathRound('0', '0');
----
0

# ----- Logical Edge Cases -----

# logicalAllTrue: mixed booleans in JSON
query I
SELECT logicalAllTrue('[true,true,true]');
----
true

# logicalAnyTrue: null-only list
query I
SELECT logicalAnyTrue('[null]');
----
false

# logicalAllFalse: empty
query I
SELECT logicalAllFalse('[]');
----
true

# logicalAnyFalse: empty
query I
SELECT logicalAnyFalse('[]');
----
false

# logicalCoalesce: single non-null
query I
SELECT logicalCoalesce('["only"]');
----
only

# logicalCoalesce: NULL input
query I
SELECT logicalCoalesce(NULL);
----
NULL

# ----- HighBoundary / LowBoundary Edge Cases -----

# HighBoundary: full datetime, precision 8 → truncate to date
query I
SELECT HighBoundary('2024-06-15T10:30:00', 8);
----
2024-06-15

# LowBoundary: full datetime, precision 8 → truncate to date
query I
SELECT LowBoundary('2024-06-15T10:30:00', 8);
----
2024-06-15
