# =====================================================================
# Phase 2: Bug Fixes — SameOrBefore/After all precision levels
# =====================================================================

# SameOrBefore with hour precision
query I
SELECT dateTimeSameOrBefore('2024-01-15T10:30:00', '2024-01-15T12:00:00', 'hour');
----
true

# SameOrBefore with minute precision
query I
SELECT dateTimeSameOrBefore('2024-01-15T10:30:00', '2024-01-15T10:45:00', 'minute');
----
true

# SameOrBefore with second precision
query I
SELECT dateTimeSameOrBefore('2024-01-15T10:30:45', '2024-01-15T10:30:50', 'second');
----
true

# SameOrBefore with millisecond precision
query I
SELECT dateTimeSameOrBefore('2024-01-15T10:30:45.100', '2024-01-15T10:30:45.200', 'millisecond');
----
true

# SameOrAfter with hour precision
query I
SELECT dateTimeSameOrAfter('2024-01-15T12:00:00', '2024-01-15T10:30:00', 'hour');
----
true

# SameOrAfter with minute precision
query I
SELECT dateTimeSameOrAfter('2024-01-15T10:45:00', '2024-01-15T10:30:00', 'minute');
----
true

# SameOrAfter with second precision
query I
SELECT dateTimeSameOrAfter('2024-01-15T10:30:50', '2024-01-15T10:30:45', 'second');
----
true

# SameOrAfter with millisecond precision
query I
SELECT dateTimeSameOrAfter('2024-01-15T10:30:45.200', '2024-01-15T10:30:45.100', 'millisecond');
----
true

# SameAs with millisecond precision
query I
SELECT dateTimeSameAs('2024-01-15T10:30:45.100', '2024-01-15T10:30:45.100', 'millisecond');
----
true

# in_valueset returns NULL when no code found
query I
SELECT in_valueset('{}', 'code', 'http://example.com/vs');
----
NULL

# in_valueset returns NULL for NULL input
query I
SELECT in_valueset(NULL, 'code', 'http://example.com/vs');
----
NULL

# =====================================================================
# Phase 3: Boundary + Interval Set Operations
# =====================================================================


# CQLPrecision — date
query I
SELECT CQLPrecision('2024-01-15');
----
8

# CQLPrecision — datetime
query I
SELECT CQLPrecision('2024-01-15T10:30:45.100');
----
17

# CQLPrecision — year only
query I
SELECT CQLPrecision('2024');
----
4

# cqlTimezoneOffset
query R
SELECT cqlTimezoneOffset('2024-01-15T10:30:00+05:30');
----
5.5

# cqlTimezoneOffset — negative
query R
SELECT cqlTimezoneOffset('2024-01-15T10:30:00-04:00');
----
-4.0

# cqlTimezoneOffset — no timezone → NULL
query I
SELECT cqlTimezoneOffset('2024-01-15T10:30:00');
----
NULL


# =====================================================================
# Phase 4: Expand + Temporal Differences
# =====================================================================


# pointFrom — unit interval
query I
SELECT pointFrom('{"low":"2024-01-01","high":"2024-01-01","lowClosed":true,"highClosed":true}');
----
2024-01-01

# pointFrom — integer unit interval
query I
SELECT pointFrom('{"low":5,"high":5,"lowClosed":true,"highClosed":true}');
----
5

# pointFrom — non-unit interval → NULL
query I
SELECT pointFrom('{"low":"2024-01-01","high":"2024-01-15","lowClosed":true,"highClosed":true}');
----
NULL

# pointFrom — open bounds → NULL
query I
SELECT pointFrom('{"low":"2024-01-01","high":"2024-01-01","lowClosed":false,"highClosed":true}');
----
NULL

# =====================================================================
# Phase 5: Math Functions
# =====================================================================

# mathAbs
query I
SELECT mathAbs('-5');
----
5

query I
SELECT mathAbs('3.14');
----
3.14

# mathCeiling
query I
SELECT mathCeiling('2.1');
----
3

# mathFloor
query I
SELECT mathFloor('2.9');
----
2

# mathRound — half-up (CQL spec)
query I
SELECT mathRound('2.5', '0');
----
3

query I
SELECT mathRound('2.4', '0');
----
2

query I
SELECT mathRound('-2.5', '0');
----
-3

# mathSqrt
query I
SELECT mathSqrt('9');
----
3

# mathSqrt negative → NULL
query I
SELECT mathSqrt('-1');
----
NULL

# mathExp
query I
SELECT mathExp('0');
----
1

# mathLn positive
query I
SELECT mathLn('1');
----
0

# mathLn zero → NULL
query I
SELECT mathLn('0');
----
NULL

# mathLn negative → NULL
query I
SELECT mathLn('-1');
----
NULL

# mathPower
query I
SELECT mathPower('2', '10');
----
1024

# mathPower fractional
query I
SELECT mathPower('4', '0.5');
----
2

# mathLog base 10
query I
SELECT mathLog('100', '10');
----
2

# mathTruncate
query I
SELECT mathTruncate('2.9');
----
2

query I
SELECT mathTruncate('-2.9');
----
-2

# NULL handling
query I
SELECT mathAbs(NULL);
----
NULL

query I
SELECT mathRound(NULL, '0');
----
NULL

# =====================================================================
# Phase 6: Quantity Arithmetic Extensions
# =====================================================================


# quantityNegate: positive → negative
query I
SELECT quantityNegate('{"value":5,"code":"mg","system":"http://unitsofmeasure.org"}');
----
{"value":-5.0,"unit":"mg","code":"mg","system":"http://unitsofmeasure.org"}

# quantityNegate: negative → positive
query I
SELECT quantityNegate('{"value":-3.5,"code":"kg","system":"http://unitsofmeasure.org"}');
----
{"value":3.5,"unit":"kg","code":"kg","system":"http://unitsofmeasure.org"}

# quantityAbs: negative
query I
SELECT quantityAbs('{"value":-7,"code":"mg","system":"http://unitsofmeasure.org"}');
----
{"value":7.0,"unit":"mg","code":"mg","system":"http://unitsofmeasure.org"}

# quantityAbs: already positive
query I
SELECT quantityAbs('{"value":7,"code":"mg","system":"http://unitsofmeasure.org"}');
----
{"value":7.0,"unit":"mg","code":"mg","system":"http://unitsofmeasure.org"}

# quantityModulo: basic
query I
SELECT quantityModulo('{"value":10,"code":"mg","system":"http://unitsofmeasure.org"}', '{"value":3,"code":"mg","system":"http://unitsofmeasure.org"}');
----
{"value":1.0,"unit":"mg","code":"mg","system":"http://unitsofmeasure.org"}

# quantityModulo: division by zero → NULL
query I
SELECT quantityModulo('{"value":10,"code":"mg","system":"http://unitsofmeasure.org"}', '{"value":0,"code":"mg","system":"http://unitsofmeasure.org"}');
----
NULL

# quantityTruncatedDivide: basic
query I
SELECT quantityTruncatedDivide('{"value":10,"code":"mg","system":"http://unitsofmeasure.org"}', '{"value":3,"code":"mg","system":"http://unitsofmeasure.org"}');
----
{"value":3.0,"unit":"mg","code":"mg","system":"http://unitsofmeasure.org"}

# quantityTruncatedDivide: negative
query I
SELECT quantityTruncatedDivide('{"value":-10,"code":"mg","system":"http://unitsofmeasure.org"}', '{"value":3,"code":"mg","system":"http://unitsofmeasure.org"}');
----
{"value":-3.0,"unit":"mg","code":"mg","system":"http://unitsofmeasure.org"}

# quantityTruncatedDivide: division by zero → NULL
query I
SELECT quantityTruncatedDivide('{"value":10,"code":"mg","system":"http://unitsofmeasure.org"}', '{"value":0,"code":"mg","system":"http://unitsofmeasure.org"}');
----
NULL

# ToQuantity: number with unit
query I
SELECT ToQuantity('5.5 ''cm''');
----
{"value":5.5,"unit":"cm","code":"cm","system":"http://unitsofmeasure.org"}

# ToQuantity: plain number
query I
SELECT ToQuantity('42');
----
{"value":42.0,"unit":"1","code":"1","system":"http://unitsofmeasure.org"}

# ToQuantity: invalid → NULL
query I
SELECT ToQuantity('abc');
----
NULL

# ToQuantity: NULL → NULL
query I
SELECT ToQuantity(NULL);
----
NULL

# ToConcept: wrap code in concept
query I
SELECT ToConcept('{"code":"123","system":"http://example.com"}');
----
{"codes":[{"code":"123","system":"http://example.com"}]}

# ToConcept: NULL → NULL
query I
SELECT ToConcept(NULL);
----
NULL


# quantityNegate: NULL → NULL
query I
SELECT quantityNegate(NULL);
----
NULL

# =====================================================================
# Phase 7: Logical Aggregates
# =====================================================================

# logicalAllTrue: all true
query I
SELECT logicalAllTrue('["true","true","true"]');
----
true

# logicalAllTrue: one false
query I
SELECT logicalAllTrue('["true","false","true"]');
----
false

# logicalAllTrue: with null (ignored per CQL §22.1)
query I
SELECT logicalAllTrue('["true",null,"true"]');
----
true

# logicalAllTrue: empty array
query I
SELECT logicalAllTrue('[]');
----
true

# logicalAllTrue: NULL input → true
query I
SELECT logicalAllTrue(NULL);
----
true

# logicalAnyTrue: one true
query I
SELECT logicalAnyTrue('["false","true","false"]');
----
true

# logicalAnyTrue: all false
query I
SELECT logicalAnyTrue('["false","false"]');
----
false

# logicalAnyTrue: all null
query I
SELECT logicalAnyTrue('[null,null]');
----
false

# logicalAnyTrue: empty
query I
SELECT logicalAnyTrue('[]');
----
false

# logicalAllFalse: all false
query I
SELECT logicalAllFalse('["false","false"]');
----
true

# logicalAllFalse: one true
query I
SELECT logicalAllFalse('["false","true"]');
----
false

# logicalAllFalse: with null (ignored)
query I
SELECT logicalAllFalse('["false",null]');
----
true

# logicalAnyFalse: has false
query I
SELECT logicalAnyFalse('["true","false"]');
----
true

# logicalAnyFalse: all true
query I
SELECT logicalAnyFalse('["true","true"]');
----
false

# logicalAnyFalse: empty
query I
SELECT logicalAnyFalse('[]');
----
false

# logicalImplies: false → anything = true
query I
SELECT logicalImplies('false', NULL);
----
true

# logicalImplies: true → true = true
query I
SELECT logicalImplies('true', 'true');
----
true

# logicalImplies: true → false = false
query I
SELECT logicalImplies('true', 'false');
----
false

# logicalImplies: true → null = null
query I
SELECT logicalImplies('true', NULL);
----
NULL

# logicalImplies: null → true = true
query I
SELECT logicalImplies(NULL, 'true');
----
true

# logicalImplies: null → false = null
query I
SELECT logicalImplies(NULL, 'false');
----
NULL

# logicalImplies: null → null = null
query I
SELECT logicalImplies(NULL, NULL);
----
NULL

# logicalCoalesce: first non-null
query I
SELECT logicalCoalesce('[null, null, "5"]');
----
5

# logicalCoalesce: first element non-null
query I
SELECT logicalCoalesce('["hello", null]');
----
hello

# logicalCoalesce: all null
query I
SELECT logicalCoalesce('[null, null]');
----
NULL

# logicalCoalesce: empty array
query I
SELECT logicalCoalesce('[]');
----
NULL

# logicalCoalesce: boolean values
query I
SELECT logicalCoalesce('[null, true, false]');
----
true

