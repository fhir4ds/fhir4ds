query I
SELECT mathSqrt('-1');
----
NULL

# mathExp
query I
SELECT mathExp('0');
----
1

# mathLn positive
query I
SELECT mathLn('1');
----
0

# mathLn zero → NULL
query I
SELECT mathLn('0');
----
NULL

# mathLn negative → NULL
query I
SELECT mathLn('-1');
----
NULL

# mathPower
