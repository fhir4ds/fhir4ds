# =====================================================================
# Ratio UDFs
# =====================================================================

# ratioNumeratorValue
query R
SELECT ratioNumeratorValue('{"numerator": {"value": 5, "unit": "mg"}, "denominator": {"value": 1, "unit": "mL"}}');
----
5.0

# ratioDenominatorValue
query R
SELECT ratioDenominatorValue('{"numerator": {"value": 5, "unit": "mg"}, "denominator": {"value": 1, "unit": "mL"}}');
----
1.0

# ratioValue (5 / 1 = 5.0)
query R
SELECT ratioValue('{"numerator": {"value": 5, "unit": "mg"}, "denominator": {"value": 1, "unit": "mL"}}');
----
5.0

# ratioValue with non-trivial division
query R
SELECT ratioValue('{"numerator": {"value": 10, "unit": "mg"}, "denominator": {"value": 4, "unit": "mL"}}');
----
2.5

# ratioValue with zero denominator returns NULL
query I
SELECT ratioValue('{"numerator": {"value": 5}, "denominator": {"value": 0}}');
----
NULL

# ratioNumeratorUnit
query I
SELECT ratioNumeratorUnit('{"numerator": {"value": 5, "unit": "mg"}, "denominator": {"value": 1, "unit": "mL"}}');
----
mg

# ratioDenominatorUnit
query I
SELECT ratioDenominatorUnit('{"numerator": {"value": 5, "unit": "mg"}, "denominator": {"value": 1, "unit": "mL"}}');
----
mL

# ratioNumeratorUnit with "code" instead of "unit"
query I
SELECT ratioNumeratorUnit('{"numerator": {"value": 5, "code": "mg"}, "denominator": {"value": 1, "code": "mL"}}');
----
mg

# Ratio NULL input
query I
SELECT ratioNumeratorValue(NULL);
----
NULL

# Ratio invalid JSON
query I
SELECT ratioValue('not json');
----
NULL

# =====================================================================
# Quantity UDFs
# =====================================================================

# quantityValue
query R
SELECT quantityValue('{"value": 140, "code": "mm[Hg]", "system": "http://unitsofmeasure.org"}');
----
140.0

# quantityUnit
query I
SELECT quantityUnit('{"value": 140, "code": "mm[Hg]", "system": "http://unitsofmeasure.org"}');
----
mm[Hg]

# quantityUnit with "unit" field instead of "code"
query I
SELECT quantityUnit('{"value": 140, "unit": "mmHg"}');
----
mmHg

# parseQuantity returns normalized JSON
query I
SELECT parseQuantity('{"value": 140, "code": "mm[Hg]"}') LIKE '%140%';
----
true

# quantityCompare - greater than
query I
SELECT quantityCompare('{"value": 140, "code": "mm[Hg]"}', '{"value": 120, "code": "mm[Hg]"}', '>');
----
true

# quantityCompare - less than
query I
SELECT quantityCompare('{"value": 100, "code": "mm[Hg]"}', '{"value": 120, "code": "mm[Hg]"}', '<');
----
true

# quantityCompare - cross-unit (hours vs minutes)
query I
SELECT quantityCompare('{"value": 1, "code": "h"}', '{"value": 30, "code": "min"}', '>');
----
true

# quantityCompare - incompatible units returns NULL
query I
SELECT quantityCompare('{"value": 1, "code": "kg"}', '{"value": 1, "code": "m"}', '>');
----
NULL

# quantityAdd - same units
query I
SELECT quantityAdd('{"value": 5, "code": "mg"}', '{"value": 3, "code": "mg"}') LIKE '%8%';
----
true

# quantityAdd - cross-unit (g + mg)
query I
SELECT quantityAdd('{"value": 1, "code": "g"}', '{"value": 500, "code": "mg"}') LIKE '%1.5%';
----
true

# quantitySubtract
query I
SELECT quantitySubtract('{"value": 10, "code": "mg"}', '{"value": 3, "code": "mg"}') LIKE '%7%';
----
true

# quantityConvert - hours to minutes
query I
SELECT quantityConvert('{"value": 2, "code": "h"}', 'min') LIKE '%120%';
----
true

# quantityConvert - kg to g
query I
SELECT quantityConvert('{"value": 1, "code": "kg"}', 'g') LIKE '%1000%';
----
true

# quantity NULL input
query I
SELECT quantityValue(NULL);
----
NULL

# snake_case alias works
query R
SELECT quantity_value('{"value": 42, "code": "mg"}');
----
42.0

# =====================================================================
# List UDFs
# =====================================================================

# SingletonFrom with exactly 1 element
query I
SELECT SingletonFrom(['hello']);
----
hello

# SingletonFrom with 0 elements returns NULL
query I
SELECT SingletonFrom(CAST([] AS VARCHAR[]));
----
NULL

# SingletonFrom with >1 elements returns NULL
query I
SELECT SingletonFrom(['a', 'b']);
----
NULL

# SingletonFrom with NULL input
query I
SELECT SingletonFrom(NULL::VARCHAR[]);
----
NULL

# ElementAt - 0-based index
query I
SELECT ElementAt(['a', 'b', 'c'], 0);
----
a

# ElementAt - second element
query I
SELECT ElementAt(['a', 'b', 'c'], 1);
----
b

# ElementAt - last element
query I
SELECT ElementAt(['a', 'b', 'c'], 2);
----
c

# ElementAt - negative index (-1 = last)
query I
SELECT ElementAt(['a', 'b', 'c'], -1);
----
c

# ElementAt - out of bounds returns NULL
query I
SELECT ElementAt(['a', 'b'], 5);
----
NULL

# ElementAt - NULL input
query I
SELECT ElementAt(NULL::VARCHAR[], 0);
----
NULL

# jsonConcat - two scalars
query I
SELECT length(jsonConcat('a', 'b'));
----
2

# jsonConcat - one NULL
query I
SELECT length(jsonConcat('a', NULL));
----
1

# jsonConcat - both NULL
query I
SELECT jsonConcat(NULL, NULL);
----
NULL

