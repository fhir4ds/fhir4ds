# ----- DateTime Comparison Extended -----

# SameAs with full precision
query I
SELECT dateTimeSameAs('2024-01-15T10:30:00.000', '2024-01-15T10:30:00.000', 'millisecond');
----
true

# SameAs with year precision only
query I
SELECT dateTimeSameAs('2024-06-15', '2024-12-31', 'year');
----
true

# SameAs with month precision
query I
SELECT dateTimeSameAs('2024-06-15', '2024-06-01', 'month');
----
true

# SameAs different years
query I
SELECT dateTimeSameAs('2024-01-01', '2025-01-01', 'year');
----
false

# SameOrBefore: equal dates
query I
SELECT dateTimeSameOrBefore('2024-01-01', '2024-01-01', 'day');
----
true

# SameOrBefore: before
query I
SELECT dateTimeSameOrBefore('2023-12-31', '2024-01-01', 'day');
----
true

# SameOrBefore: after
query I
SELECT dateTimeSameOrBefore('2024-01-02', '2024-01-01', 'day');
----
false

# SameOrAfter: equal dates
query I
SELECT dateTimeSameOrAfter('2024-01-01', '2024-01-01', 'day');
----
true

# SameOrAfter: after
query I
SELECT dateTimeSameOrAfter('2024-01-02', '2024-01-01', 'day');
----
true

# SameOrAfter: before
query I
SELECT dateTimeSameOrAfter('2023-12-31', '2024-01-01', 'day');
----
false

# SameOrBefore with hour precision
query I
SELECT dateTimeSameOrBefore('2024-01-01T10:00:00', '2024-01-01T11:00:00', 'hour');
----
true

# SameOrAfter with minute precision
query I
SELECT dateTimeSameOrAfter('2024-01-01T10:30:00', '2024-01-01T10:30:00', 'minute');
----
true

# SameOrBefore with second precision
query I
SELECT dateTimeSameOrBefore('2024-01-01T10:30:00', '2024-01-01T10:30:01', 'second');
----
true

# SameOrBefore with millisecond precision
query I
SELECT dateTimeSameOrBefore('2024-01-01T10:30:00.000', '2024-01-01T10:30:00.001', 'millisecond');
----
true

