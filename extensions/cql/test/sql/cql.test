# =====================================================================
# Bug 4: parse_quantity must preserve "unit" field in output
# =====================================================================

# parse_quantity should include "unit" in output
query I
SELECT parse_quantity('{"value":1.1,"unit":"mg/dL","system":"http://unitsofmeasure.org","code":"mg/dL"}') LIKE '%"unit":"mg/dL"%';
----
true

# parse_quantity with only "unit" (no "code") should also have "unit" in output
query I
SELECT parse_quantity('{"value":2.5,"unit":"kg"}') LIKE '%"unit":"kg"%';
----
true

# parse_quantity with only "code" should synthesize "unit" from "code"
query I
SELECT parse_quantity('{"value":3.0,"code":"mg/dL","system":"http://unitsofmeasure.org"}') LIKE '%"unit":"mg/dL"%';
----
true

