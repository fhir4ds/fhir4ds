# Bug 6: *Between date-difference macros
# =====================================================================

query I
SELECT DaysBetween('2024-01-01', '2024-12-31');
----
365

query I
SELECT HoursBetween('2024-01-01T00:00:00', '2024-01-01T06:00:00');
----
6

query I
SELECT MonthsBetween('2024-01-01', '2024-06-01');
----
5

query I
SELECT YearsBetween('2020-01-01', '2024-01-01');
----
4

query I
SELECT MinutesBetween('2024-01-01T00:00:00', '2024-01-01T01:30:00');
----
90

query I
SELECT SecondsBetween('2024-01-01T00:00:00', '2024-01-01T00:01:30');
----
90

# Between with NULL inputs → NULL
query I
SELECT DaysBetween(NULL, '2024-01-01');
----
NULL

