    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "dotenv": "^17.4.1",
    "typescript": "~5.8.0",
    "vite": "^6.3.0"
