{
    "_comment": "Maps FHIR element types to DuckDB fhirpath UDF function names and SQL column types",
    "type_mappings": {
        "dateTime":         {"udf": "fhirpath_date",   "sql_type": "DATE"},
        "date":             {"udf": "fhirpath_date",   "sql_type": "DATE"},
        "instant":          {"udf": "fhirpath_date",   "sql_type": "TIMESTAMP"},
        "Period":           {"udf": "fhirpath_date",   "sql_type": "DATE"},
        "boolean":          {"udf": "fhirpath_bool",   "sql_type": "BOOLEAN"},
        "integer":          {"udf": "fhirpath_number", "sql_type": "INTEGER"},
        "positiveInt":      {"udf": "fhirpath_number", "sql_type": "INTEGER"},
        "unsignedInt":      {"udf": "fhirpath_number", "sql_type": "INTEGER"},
        "decimal":          {"udf": "fhirpath_number", "sql_type": "DOUBLE"},
        "Quantity":         {"udf": "fhirpath_number", "sql_type": "DOUBLE"},
        "string":           {"udf": "fhirpath_text",   "sql_type": "VARCHAR"},
        "code":             {"udf": "fhirpath_text",   "sql_type": "VARCHAR"},
        "uri":              {"udf": "fhirpath_text",   "sql_type": "VARCHAR"},
        "canonical":        {"udf": "fhirpath_text",   "sql_type": "VARCHAR"},
        "id":               {"udf": "fhirpath_text",   "sql_type": "VARCHAR"},
        "markdown":         {"udf": "fhirpath_text",   "sql_type": "VARCHAR"},
        "CodeableConcept":  {"udf": "fhirpath_text",   "sql_type": "VARCHAR"},
        "Reference":        {"udf": "fhirpath_text",   "sql_type": "VARCHAR"}
    },
    "column_to_fhir_paths": {
        "onset_date":             ["onset[x]", "onsetDateTime"],
        "abatement_date":         ["abatement[x]", "abatementDateTime"],
        "abatement_end_date":     ["abatement[x]", "abatementPeriod"],
        "recorded_date":          ["recordedDate"],
        "effective_date":         ["effective[x]", "effectiveDateTime", "effectivePeriod"],
        "period_start":           ["period"],
        "period_end":             ["period"],
        "performed_date":         ["performed[x]", "performedDateTime"],
        "performed_start":        ["performed[x]", "performedPeriod"],
        "performed_end":          ["performed[x]", "performedPeriod"],
        "authored_date":          ["authoredOn"],
        "authored_on":            ["authoredOn"],
        "occurrence_date_time":   ["occurrence[x]", "occurrenceDateTime"],
        "status":                 ["status"],
        "verification_status":    ["verificationStatus"],
        "clinical_status":        ["clinicalStatus"],
        "code":                   ["code"],
        "vaccine_code":           ["vaccineCode"],
        "class_code":             ["class"],
        "type":                   ["type"],
        "type_code":              ["type"],
        "discharge_code":         ["hospitalization"],
        "value_quantity":         ["value[x]", "valueQuantity"],
        "value":                  ["value[x]", "valueQuantity"],
        "component":              ["component"],
        "issued":                 ["issued"],
        "intent":                 ["intent"],
        "medication":             ["medication", "medicationCodeableConcept", "medicationReference"],
        "birth_date":             ["birthDate"],
        "gender":                 ["gender"],
        "active":                 ["active"],
        "deceased":               ["deceased[x]", "deceasedBoolean", "deceasedDateTime"]
    }
}
